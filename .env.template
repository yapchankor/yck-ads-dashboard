# Environment Variables Template
# Copy this to .env and fill in your actual values

# Google API Credentials
# Get these from: https://console.cloud.google.com/
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json

# Modal (for cloud webhooks)
# Get from: https://modal.com/
MODAL_TOKEN_ID=your_modal_token_id_here
MODAL_TOKEN_SECRET=your_modal_token_secret_here

# Email Configuration (for webhook notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# Slack (for webhook activity streaming)
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# Google Ads API Credentials
# Get these from: https://developers.google.com/google-ads/api/docs/first-call/overview
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_CLIENT_ID=your_client_id_here
GOOGLE_ADS_CLIENT_SECRET=your_client_secret_here
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here
GOOGLE_ADS_LOGIN_CUSTOMER_ID=your_manager_account_id_here

# Facebook/Meta Ads API Credentials
# Get these from: https://developers.facebook.com/apps/
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token_here
FACEBOOK_AD_ACCOUNT_ID=act_your_ad_account_id_here

# ADSPULSE frontend -> Modal API proxy
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
CLERK_SIGN_IN_URL=/sign-in
CLERK_SIGN_UP_URL=/sign-up
CLERK_AFTER_SIGN_IN_URL=/
CLERK_AFTER_SIGN_UP_URL=/
MODAL_API_BASE_URL=https://your-modal-dashboard-endpoint.modal.run
MODAL_APPLY_URL=https://your-modal-apply-endpoint.modal.run
MODAL_TRACKING_URL=https://your-modal-tracking-endpoint.modal.run
MODAL_TRACKING_DELETE_URL=https://your-modal-tracking-delete-endpoint.modal.run
MODAL_REFRESH_URL=https://your-modal-refresh-endpoint.modal.run
MODAL_EMAIL_SETTINGS_URL=https://your-modal-email-settings-endpoint.modal.run
MODAL_EMAIL_SETTINGS_UPDATE_URL=https://your-modal-email-settings-update-endpoint.modal.run
ADSPULSE_INTERNAL_API_KEY=generate_a_strong_random_key
ADSPULSE_DEFAULT_CLIENT_NAME=YAP CHAN KOR
ADSPULSE_ALLOWED_CLIENTS=YAP CHAN KOR

# Other API Keys (add as needed)
# OPENAI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here
